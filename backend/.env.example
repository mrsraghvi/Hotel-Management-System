# ============================================================
# Hotel Management System - Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=hotel_management

# JWT Configuration
JWT_SECRET=hotel_management_super_secret_key_2024_change_this
JWT_EXPIRES_IN=7d

# Tax Configuration
TAX_RATE=18

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
